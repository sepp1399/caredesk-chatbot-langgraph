# ── Google Gemini ─────────────────────────────────────────────────────────────
# The only required setting. Get a key at https://aistudio.google.com/apikey

GEMINI_API_KEY=<your-gemini-api-key>

# Main chat model used by every flow agent.
GEMINI_MODEL=gemini-2.5-flash

# Smaller/faster model used by the intent classifier (orchestrator).
GEMINI_ROUTER_MODEL=gemini-2.5-flash-lite

# ── CareDesk booking backend (in-memory mock) ─────────────────────────────────
# The booking backend is a self-contained in-memory mock — no external API,
# tenant or token is required. These knobs only tweak the demo behaviour.

# Tenant slug used when formatting demo handoff links.
CAREDESK_INSTANCE_ID=caredesk-demo

# Fallback user id when no caller is authenticated (matches a seeded demo user).
CAREDESK_TEST_USER_ID=usr_demo_001

# When truthy, exposes hidden ("weboff") activities/doctors so the agent can
# warn the patient that they require an operator / web portal.
CAREDESK_MANAGE_WEBOFF=false

# ── Prompts ───────────────────────────────────────────────────────────────────

# Optional override path for the prompt dictionary TSV.
# Defaults to <repo-root>/Voicebot_Chatbot_Chiavi.tsv when unset.
PROMPTS_TSV_PATH=

# Lookup keys used when resolving entries in the prompt dictionary.
PROMPTS_INSTANCE=caredesk-demo
PROMPTS_LANG=it

# Output language for the bot (it | en). Drives static-message bundles
# and is injected as a "respond in <lang>" directive into every prompt.
BOT_LANG=it

# ── Knowledge base (optional OpenSearch backend) ──────────────────────────────

OPENSEARCH_HOST=localhost
OPENSEARCH_PORT=9200
OPENSEARCH_PASSWORD=<your-opensearch-password>
OPENSEARCH_INDEX=clinical_kb
EMBEDDING_DIMENSIONS=1536

# ── Observability (optional Langfuse) ─────────────────────────────────────────
# Leave both keys empty to disable LangChain tracing. When set, every
# orchestrator call and every flow-agent turn is traced and grouped by
# `session_id` in the Langfuse UI.

# Langfuse instance URL. Defaults to the managed cloud workspace.
# Use `LANGFUSE_HOST` instead for back-compat with the official SDK env.
LANGFUSE_BASE_URL=https://cloud.langfuse.com
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# ── Application ───────────────────────────────────────────────────────────────

# Python logging level for the `caredesk_lg` logger tree.
LOG_LEVEL=INFO

# Comma-separated list of allowed origins, or `*` for development.
# Example for production: https://chat.example.com,https://www.example.com
CORS_ORIGINS=*
